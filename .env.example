# --- STT ---
DEEPGRAM_API_KEY=

# --- TTS ---
# "cartesia" or "deepgram". Deepgram TTS (Aura-2) reuses DEEPGRAM_API_KEY
# above — no separate signup needed. Switch here if you hit Cartesia's
# free-tier limit; no code changes required.
TTS_PROVIDER=cartesia

CARTESIA_API_KEY=
# Optional: pick a different Cartesia voice id. Default below is "Helpful Woman".
CARTESIA_VOICE_ID=79a125e8-cd45-4c13-8a67-188112f4dd22

# Deepgram Aura-2 model = voice, in one string ("aura-2-<voicename>-en").
# Browse voices at https://developers.deepgram.com/docs/tts-models
# A few good conversational options: aura-2-thalia-en (bright/dynamic),
# aura-2-selene-en (soft), aura-2-theia-en (professional).
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# --- LLM (Groq) ---
GROQ_API_KEY=

# --- Qdrant ---
# "local" = docker-compose Qdrant on localhost:6333 (default, free)
# "cloud" = Qdrant Cloud, set QDRANT_URL + QDRANT_API_KEY to your cluster
QDRANT_MODE=local
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=pride_and_prejudice

# --- Server ---
HOST=0.0.0.0
PORT=7860

# --- Turn-taking ---
# Seconds of silence required before the agent considers you done talking.
# Raise this (e.g. 1.0-1.2) if it still interrupts you mid-sentence;
# lower it (e.g. 0.5) if responses feel sluggish after you actually finish.
VAD_STOP_SECS=0.8
