# --- STT ---
DEEPGRAM_API_KEY=

# --- TTS ---
CARTESIA_API_KEY=
# Optional: pick a different Cartesia voice id. Default below is "Helpful Woman".
CARTESIA_VOICE_ID=

# --- LLM (Groq) ---
GROQ_API_KEY=

# --- Qdrant ---
# "local" = docker-compose Qdrant on localhost:6333 (default, free)
# "cloud" = Qdrant Cloud, set QDRANT_URL + QDRANT_API_KEY to your cluster
QDRANT_MODE=local
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=pride_and_prejudice

# --- Server ---
HOST=0.0.0.0
PORT=7860
